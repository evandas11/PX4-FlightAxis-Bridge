#!/bin/sh
#
# @name FlightAxis Plane
#
# @type Plane
#

. ${R}etc/init.d/rc.fw_defaults

# RealFlight free-runs (no lockstep), GPS samples arrive fresh.
# Forced with "param set": px4-rc.mavlinksim runs after this file and would
# otherwise override the default back to 10 ms.
param set EKF2_GPS_DELAY 0

# rcS sets SDLOG_MODE 1 ("from boot until disarm"), which closes the log at the
# FIRST disarm; the spec section 11 validation checklist spans several arm/disarm
# cycles, so most of it -- including the groundtruth-vs-estimate check -- would
# never reach a log. Mode 4 is "from 1st armed until shutdown". SDLOG_MODE is
# @reboot_required, so this has to be a startup default, not a pxh> command.
param set-default SDLOG_MODE 4

# The bridge supplies the battery from RealFlight's own model (pack voltage and
# current draw, or fuel remaining on internal-combustion models), so PX4's
# synthetic battery must be switched off or the two publishers alternate on the
# battery_status topic and the reading flickers between them.
#
# The bridge sends BATTERY_STATUS on UDP 14580+instance, which reaches
# MavlinkReceiver::handle_message_battery_status(); the simulator link on TCP
# 4560 cannot carry it, because SimulatorMavlink::handle_message() has no
# BATTERY_STATUS case at all. See Tools/simulation/flightaxis/flightaxis_bridge/
# src/battery_link.h for the full reasoning.
#
# If the bridge cannot open that socket it says so and PX4 is left with no
# battery: set this back to 1 in that case.
param set SIM_BAT_ENABLE 0

# Only IMU instance 0 is ever supplied: the bridge sends HIL_SENSOR with id = 0,
# so SimulatorMavlink only ever fills _px4_accel[0]/_px4_gyro[0]. px4-rc.mavlinksim
# asks for 3, which leaves two EKF instances running on dead sensors.
# Forced with "param set": px4-rc.mavlinksim runs after this file and would
# otherwise override the default back to 3. Note 0 is not an alternative --
# EKF2.cpp clamps EKF2_MULTI_IMU to a minimum of 1 whenever SENS_IMU_MODE is 0.
param set EKF2_MULTI_IMU 1

# Headless runs (QGC optional) have no manual control source at all. Value 4
# ("ignore any stick input") is the only value that skips the RC-loss failsafe;
# rcS's default of 1 does not. Without this, RC-loss failsafe is avoided only by
# the _manual_control_lost_at_arming fallback, which stops applying if manual
# control is ever briefly present. NAV_RCL_ACT is deliberately left at its
# firmware default: it is unreachable once COM_RC_IN_MODE is 4, and the value 0
# suggested for it is outside the parameter's declared range (@min 1).
#
# THIS ALSO BLOCKS RC TRANSMITTER PASSTHROUGH, and that is a deliberate trade
# rather than an oversight. The bridge forwards a physical transmitter plugged
# into RealFlight to PX4 as RC_CHANNELS -> input_rc (see the RC block in
# vehicle_state.h). That stream is sent regardless of this parameter, and
# "listener input_rc" will show the live stick values either way - but value 4
# makes commander ignore them, so the sticks will neither arm nor fly the
# aircraft. If passthrough looks broken while input_rc is populated and moving,
# this parameter is why.
#
# No single value serves both cases, because PX4 overloads this one parameter
# for both jobs: the SAME value 4 is what skips the RC-loss failsafe
# (failsafe.cpp:479, tested against RcInMode::StickInputDisabled) and what gates
# the manual-mode arming check (modeCheck.cpp:154). Any value that enables the
# sticks therefore necessarily re-arms the RC-loss failsafe, and a headless run
# with no transmitter would take a failsafe action (NAV_RCL_ACT, default
# 2 = Return) as soon as it armed. Defaulting to the transmitter case would
# break every user who does not have one - the common case - while defaulting
# to headless costs the transmitter user exactly one line, set at the pxh>
# prompt or added to this file:
#
#     param set COM_RC_IN_MODE 0     # RC transmitter only
#
# Use 0 when the transmitter is the only stick source (it also keeps a QGC
# virtual joystick from competing with it), or 2 to allow a transmitter and a
# QGC joystick with fallback. The transmitter must then be calibrated in QGC
# exactly as for real hardware (Vehicle Setup -> Radio): PX4 does not act on
# input_rc until RC_MAP_* and the per-channel RC_MIN/RC_TRIM/RC_MAX are set.
param set-default COM_RC_IN_MODE 4

# PX4's remaining-flight-time failsafe cannot work with a MAVLink-injected
# battery, and its default action is Return.
#
# The bridge feeds RealFlight's real pack voltage, current and fuel to PX4 as
# BATTERY_STATUS. But mavlink_receiver's handler never sets
# battery_status.time_remaining_s, so it keeps the zero from struct
# initialisation. batteryCheck.cpp then reads that 0.0, PX4_ISFINITE(0.0) is
# true, and PX4 concludes there are zero seconds of flight left - so
# COM_FLTT_LOW_ACT 3 fires an RTL within seconds of arming, every time.
#
# This is structural: the estimate is not something we can supply through that
# message, so acting on it means acting on a number PX4 never received. Set to
# None. Low-battery protection is unaffected - BAT_LOW_THR, BAT_CRIT_THR and
# BAT_EMERGEN_THR all act on "remaining", which the bridge does supply.
# Forced with "param set", not set-default: a value saved from an earlier
# session would otherwise win and bring the RTL straight back. The same
# applies to SIM_BAT_ENABLE above - two battery publishers fighting is worse
# than either alone. Both are requirements of this integration rather than
# preferences, so they are not left to whatever is in parameters.bson.
param set COM_FLTT_LOW_ACT 0

param set-default FW_LND_ANG 5
param set-default FW_LND_FLALT 5
# Flare pitch window: firmware defaults (2.5/15) are too narrow to land here
param set-default FW_LND_FL_PMIN 9.5
param set-default FW_LND_FL_PMAX 20

param set-default NPFG_PERIOD 25

param set-default FW_PR_FF 0.40
param set-default FW_PR_I 0.05
param set-default FW_PR_P 0.05

param set-default FW_R_TC 0.45
param set-default FW_RR_FF 0.40
param set-default FW_RR_I 0.132
param set-default FW_RR_P 0.085

param set-default MIS_TAKEOFF_ALT 20

param set-default NAV_ACC_RAD 15

param set-default RWTO_TKOFF 1
param set-default RWTO_PSP 8

# Actuator geometry (QGC Actuators tab) MUST match the "px4" output indices
# in Tools/simulation/flightaxis/flightaxis_bridge/models/plane.json.
#
# PWM_MAIN_FUNC<N> lands on HIL_ACTUATOR_CONTROLS.controls[N-1], so the
# assignments below produce:
#
#   controls[0] = 101 Motor 1     throttle        [0,1]  -> plane.json rf2
#   controls[1] = 201 Servo 1     aileron left    [-1,1] -> plane.json rf0
#   controls[2] = 202 Servo 2     aileron right   [-1,1] -> unmapped (see plane.json)
#   controls[3] = 203 Servo 3     elevator        [-1,1] -> plane.json rf1
#   controls[4] = 204 Servo 4     rudder          [-1,1] -> plane.json rf3
param set-default CA_AIRFRAME 1

param set-default CA_ROTOR_COUNT 1
param set-default CA_ROTOR0_PX 0.3

param set-default CA_SV_CS_COUNT 4
param set-default CA_SV_CS0_TRQ_R -0.5
param set-default CA_SV_CS0_TYPE 1
param set-default CA_SV_CS1_TRQ_R 0.5
param set-default CA_SV_CS1_TYPE 2
param set-default CA_SV_CS2_TRQ_P 1
param set-default CA_SV_CS2_TYPE 3
param set-default CA_SV_CS3_TRQ_Y 1
param set-default CA_SV_CS3_TYPE 4

param set-default PWM_MAIN_FUNC1 101
param set-default PWM_MAIN_FUNC2 201
param set-default PWM_MAIN_FUNC3 202
param set-default PWM_MAIN_FUNC4 203
param set-default PWM_MAIN_FUNC5 204
